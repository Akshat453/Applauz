generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Role {
  id          String @id @default(uuid()) @db.Uuid
  name        String @unique @db.VarChar(50)
  permissions Json
  users       User[]

  @@map("roles")
}

model Department {
  id          String  @id @default(uuid()) @db.Uuid
  name        String  @unique @db.VarChar(50)
  description String? @db.Text
  users       User[]

  @@map("departments")
}

model User {
  id                     String             @id @default(uuid()) @db.Uuid
  employee_code          String             @unique @db.VarChar(50)
  name                   String             @db.VarChar(120)
  email                  String             @unique @db.VarChar(255)
  password_hash          String
  role_id                String             @db.Uuid
  department_id          String?            @db.Uuid
  manager_id             String?            @db.Uuid
  points_balance         Int                @default(0)
  avatar_url             String?            @db.VarChar(255)
  status                 String             @default("active") @db.VarChar(50)
  created_at             DateTime           @default(now())
  updated_at             DateTime           @default(now()) @updatedAt
  role                   Role               @relation(fields: [role_id], references: [id])
  department             Department?        @relation(fields: [department_id], references: [id])
  manager                User?              @relation("ManagerReports", fields: [manager_id], references: [id])
  direct_reports         User[]             @relation("ManagerReports")
  recognitions_sent      Recognition[]      @relation("RecognitionSender")
  recognitions_received  Recognition[]      @relation("RecognitionReceiver")
  recognitions_approved  Recognition[]      @relation("RecognitionApprover")
  points_transactions    PointTransaction[] @relation("UserPointTransactions")
  created_transactions   PointTransaction[] @relation("PointTransactionCreator")
  managed_points_budgets PointBudget[]      @relation("ManagerPointsBudgets")
  redemptions            Redemption[]       @relation("RedemptionUser")
  approved_redemptions   Redemption[]       @relation("RedemptionApprover")

  @@map("users")
}

model RecognitionCategory {
  id             String        @id @default(uuid()) @db.Uuid
  name           String        @unique @db.VarChar(50)
  icon           String?       @db.VarChar(255)
  default_points Int
  recognitions   Recognition[]

  @@map("recognition_categories")
}

model Recognition {
  id                 String               @id @default(uuid()) @db.Uuid
  sender_id          String               @db.Uuid
  receiver_id        String               @db.Uuid
  category_id        String?              @db.Uuid
  message            String               @db.Text
  points_recommended Int?
  points_awarded     Int?
  status             String               @default("pending") @db.VarChar(50)
  approver_id        String?              @db.Uuid
  rejection_reason   String?              @db.Text
  reviewed_at        DateTime?
  visibility         String               @default("public") @db.VarChar(50)
  created_at         DateTime             @default(now())
  sender             User                 @relation("RecognitionSender", fields: [sender_id], references: [id])
  receiver           User                 @relation("RecognitionReceiver", fields: [receiver_id], references: [id])
  category           RecognitionCategory? @relation(fields: [category_id], references: [id])
  approver           User?                @relation("RecognitionApprover", fields: [approver_id], references: [id])

  @@map("recognitions")
}

model PointTransaction {
  id            String   @id @default(uuid()) @db.Uuid
  user_id       String   @db.Uuid
  type          String   @db.VarChar(50)
  source_type   String   @db.VarChar(50)
  source_id     String?  @db.Uuid
  points        Int
  balance_after Int
  created_by    String?  @db.Uuid
  created_at    DateTime @default(now())
  user          User     @relation("UserPointTransactions", fields: [user_id], references: [id])
  creator       User?    @relation("PointTransactionCreator", fields: [created_by], references: [id])

  @@map("points_transactions")
}

model PointBudget {
  id               String   @id @default(uuid()) @db.Uuid
  manager_id       String   @db.Uuid
  allocated_points Int
  used_points      Int      @default(0)
  period_start     DateTime @db.Date
  period_end       DateTime @db.Date
  manager          User     @relation("ManagerPointsBudgets", fields: [manager_id], references: [id])

  @@map("points_budget")
}

model RewardCatalog {
  id             String       @id @default(uuid()) @db.Uuid
  title          String       @db.VarChar(120)
  description    String?      @db.Text
  category       String       @db.VarChar(50)
  points_cost    Int
  stock_quantity Int?
  image_url      String?      @db.VarChar(255)
  is_active      Boolean      @default(true)
  created_at     DateTime     @default(now())
  updated_at     DateTime     @default(now()) @updatedAt
  redemptions    Redemption[]

  @@map("rewards_catalog")
}

model Redemption {
  id               String        @id @default(uuid()) @db.Uuid
  user_id          String        @db.Uuid
  reward_id        String        @db.Uuid
  points_spent     Int
  status           String        @default("pending") @db.VarChar(50)
  approved_by      String?       @db.Uuid
  approved_at      DateTime?
  rejection_reason String?       @db.Text
  requested_at     DateTime      @default(now())
  user             User          @relation("RedemptionUser", fields: [user_id], references: [id])
  reward           RewardCatalog @relation(fields: [reward_id], references: [id])
  approver         User?         @relation("RedemptionApprover", fields: [approved_by], references: [id])

  @@map("redemptions")
}
